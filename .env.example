# Copy to .env and adjust. All values have safe development defaults.

# Secret key for signing session cookies. REQUIRED in production.
REELFIT_SECRET_KEY=change-me

# SQLAlchemy database URL. Defaults to local SQLite for development.
# Production: postgresql+psycopg://user:pass@host:5432/reelfit
DATABASE_URL=sqlite:///./reelfit.db

# Set to "1" to enable debug mode (auto-reload, verbose errors).
REELFIT_DEBUG=1
